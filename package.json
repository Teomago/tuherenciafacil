{
  "name": "tuherenciafacil",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@payloadcms/db-postgres": "3.82.0",
    "@payloadcms/live-preview-react": "^3.82.0",
    "@payloadcms/next": "3.82.0",
    "@payloadcms/plugin-cloud-storage": "^3.82.0",
    "@payloadcms/plugin-nested-docs": "^3.82.0",
    "@payloadcms/plugin-seo": "^3.82.0",
    "@payloadcms/richtext-lexical": "3.82.0",
    "@payloadcms/storage-s3": "^3.82.0",
    "@payloadcms/translations": "^3.82.0",
    "@payloadcms/ui": "3.82.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@veiag/payload-cmdk": "^1.1.0",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "dequal": "^2.0.3",
    "dotenv": "16.4.7",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "focus-trap-react": "^12.0.0",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "graphql": "^16.8.1",
    "lucide-react": "^1.6.0",
    "marked": "^17.0.5",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "payload": "3.82.0",
    "postcss": "^8.5.8",
    "qs-esm": "^7.0.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-intersection-observer": "^10.0.3",
    "react-remove-scroll": "^2.7.2",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "standard-slugify": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "thumbhash": "^0.1.1",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
