DATABASE_URI=postgresql://neondb_owner:[id_owner]:[password]-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require
DATABASE_URI_DIRECT=postgresql://neondb_owner:[id_owner]:[password].c-6.us-east-1.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Added by Payload

# S3 Storage
S3_BUCKET=[bucket_name]
S3_ACCESS_KEY_ID=[access_key_id]
S3_SECRET_ACCESS_KEY=[secret_access_key]
S3_REGION=auto
S3_ENDPOINT=[endpoint]

#Brevo
BREVO_API_KEY=[api_key]
BREVO_EMAILS_ACTIVE=true
BREVO_SENDER_NAME=[sender_name]
BREVO_SENDER_EMAIL=[sender_email]

# Public site URL (must include scheme: https:// or http://). Bare hostnames like example.com are invalid for Payload.
# Must match the origin you use in the browser (including www vs apex).
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Password for docs
NEXT_PUBLIC_DOCS_PASS=[docs_password]
NEXT_PUBLIC_ADMIN_EMAIL=[admin_email]
