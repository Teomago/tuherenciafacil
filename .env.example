DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (must include scheme: https:// or http://). Bare hostnames like example.com are invalid for Payload.
# Must match the origin you use in the browser (including www vs apex).
# Local: http://localhost:3000 — Production: https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
